project     = "myproject"
environment = "staging"
region      = "ap-south-1"

# -----------------------------------------------------------------------
# RESOURCE CREATION FLAGS
# -----------------------------------------------------------------------
create = {
  iam        = true
  networking = true
  s3         = true

  security_groups = true

  vpc_endpoints = true
  acm           = true
  eks           = true
  elasticache   = true
  efs           = true

  devops_ec2    = true
  load_balancer = true

  cloudfront = true

  observability = true
}

# -----------------------------------------------------------------------
# Networking (2 AZs — cost-optimised vs prod's 3)
# -----------------------------------------------------------------------
vpc_cidr           = "10.2.0.0/16"
availability_zones = ["ap-south-1a", "ap-south-1b"]

public_subnet_cidrs      = ["10.2.1.0/24", "10.2.2.0/24"]
private_app_subnet_cidrs = ["10.2.11.0/24", "10.2.12.0/24"]
private_db_subnet_cidrs  = ["10.2.21.0/24", "10.2.22.0/24"]

# -----------------------------------------------------------------------
# DNS / ACM
# -----------------------------------------------------------------------
hosted_zone_name          = "example.com"
domain_name               = "staging.example.com"
subject_alternative_names = []

# Obtain via: aws route53 list-hosted-zones-by-name --dns-name example.com
route53_zone_id = "Z1234567890ABCDEFGHIJ"

# -----------------------------------------------------------------------
# IAM / GitHub OIDC
# -----------------------------------------------------------------------
github_org  = "your-github-org"
github_repo = "your-repo-name"

terraform_state_bucket = "your-tf-state-bucket-name"
terraform_lock_table   = "terraform-state-lock"

# -----------------------------------------------------------------------
# EKS — SPOT instances for cost saving
# -----------------------------------------------------------------------
kubernetes_version = "1.32"

eks_node_groups = {
  general = {
    instance_types = ["t3.large"]
    capacity_type  = "SPOT"
    desired_size   = 2
    min_size       = 1
    max_size       = 5
    disk_size_gb   = 30
    labels         = {}
    taints         = []
  }
}

eks_addon_versions = {
  coredns    = "v1.11.4-eksbuild.2"
  kube_proxy = "v1.32.3-eksbuild.2"
  vpc_cni    = "v1.19.3-eksbuild.1"
  ebs_csi    = "v1.40.0-eksbuild.1"
  efs_csi    = "v2.1.6-eksbuild.1"
}

# -----------------------------------------------------------------------
# Load Balancer
# -----------------------------------------------------------------------
alb_target_groups = {
  api = {
    port              = 8080
    health_check_path = "/health"
  }
}

alb_listener_rules = {
  api = {
    priority         = 100
    target_group_key = "api"
    path_patterns    = ["/api/*"]
  }
}

# -----------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------
alarm_email_endpoints = []

# -----------------------------------------------------------------------
# Sensitive — set via environment variables
# -----------------------------------------------------------------------
# export TF_VAR_cloudfront_origin_verify_secret="$(openssl rand -hex 32)"
